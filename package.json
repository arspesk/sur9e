{
  "name": "sur9e",
  "version": "0.1.0",
  "description": "AI-powered job search pipeline built on Claude Code",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "start": "next start -p 3000",
    "web": "node scripts/web.mjs",
    "web:prod": "node scripts/web.mjs --prod",
    "web:tailscale": "node scripts/web.mjs --tailscale",
    "web:status": "node scripts/web.mjs status",
    "web:stop": "node scripts/web.mjs stop",
    "doctor": "node cli/doctor.mjs",
    "diagnose": "node scripts/diagnose-providers.mjs",
    "tracker:verify": "node cli/verify-pipeline.mjs",
    "tracker:normalize": "node cli/normalize-statuses.mjs",
    "tracker:dedup": "node cli/dedup-tracker.mjs",
    "tracker:merge": "node cli/merge-tracker.mjs",
    "cv:pdf": "node cli/generate-pdf.mjs",
    "cv:sync-check": "node cli/cv-sync-check.mjs",
    "update:check": "node update-system.mjs check",
    "update:apply": "node update-system.mjs apply",
    "update:rollback": "node update-system.mjs rollback",
    "jobs:liveness": "tsx cli/check-liveness.mjs",
    "scan": "node batch/scan-portals.mjs && node batch/scan-jobspy.mjs",
    "setup": "npm install && node scripts/setup.mjs",
    "lint": "biome check . && prettier --check \"**/*.{md,yml,yaml}\" --ignore-path .prettierignore --ignore-path .gitignore --ignore-path .prettierignore.local",
    "format": "biome check --write . && prettier --write \"**/*.{md,yml,yaml}\" --ignore-path .prettierignore --ignore-path .gitignore --ignore-path .prettierignore.local",
    "typecheck": "tsc -p tsconfig.json",
    "test": "node test-all.mjs",
    "test:quick": "node test-all.mjs --quick",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ci": "start-server-and-test 'next dev -p 3000' http://localhost:3000 'playwright test'",
    "lighthouse": "node scripts/lighthouse-baseline.mjs",
    "preinstall": "node scripts/check-node.mjs",
    "postinstall": "git config --local core.hooksPath .githooks 2>/dev/null || true"
  },
  "keywords": [
    "ai",
    "job-search",
    "claude-code",
    "career",
    "automation"
  ],
  "author": "Arsenii Peskovatskov <arspesk@gmail.com> (https://apelabs.dev)",
  "homepage": "https://sur9e.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/arspesk/sur9e"
  },
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@emoji-mart/data": "^1.2.1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-virtual": "^3.14.2",
    "@tiptap/core": "^3.23.4",
    "@tiptap/extension-bubble-menu": "^3.23.4",
    "@tiptap/extension-character-count": "^3.23.6",
    "@tiptap/extension-code-block-lowlight": "^3.23.6",
    "@tiptap/extension-color": "^3.23.6",
    "@tiptap/extension-details": "^3.23.6",
    "@tiptap/extension-drag-handle": "^3.23.4",
    "@tiptap/extension-highlight": "^3.23.6",
    "@tiptap/extension-image": "^3.23.6",
    "@tiptap/extension-link": "^3.23.4",
    "@tiptap/extension-placeholder": "^3.23.4",
    "@tiptap/extension-table": "^3.23.4",
    "@tiptap/extension-table-cell": "^3.23.4",
    "@tiptap/extension-table-header": "^3.23.4",
    "@tiptap/extension-table-row": "^3.23.4",
    "@tiptap/extension-task-item": "^3.23.4",
    "@tiptap/extension-task-list": "^3.23.4",
    "@tiptap/extension-text-style": "^3.23.6",
    "@tiptap/extension-underline": "^3.23.6",
    "@tiptap/react": "^3.23.4",
    "@tiptap/starter-kit": "^3.23.4",
    "@tiptap/suggestion": "^3.23.4",
    "@types/mime-types": "^3.0.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cron-parser": "^5.5.0",
    "dotenv": "^16.4.5",
    "emoji-mart": "^5.6.0",
    "js-tiktoken": "^1.0.21",
    "js-yaml": "^4.1.1",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.17.0",
    "marked": "^14.1.4",
    "mime-types": "^3.0.2",
    "next": "^16.2.6",
    "playwright": "^1.58.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.6.0",
    "tippy.js": "^6.3.7",
    "tiptap-markdown": "^0.9.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@next/bundle-analyzer": "^16.2.6",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "chrome-launcher": "^1.2.1",
    "jsdom": "^29.1.1",
    "lighthouse": "^13.3.0",
    "prettier": "3.8.3",
    "start-server-and-test": "^3.0.5",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.0",
    "typescript": "^5.7.3",
    "vitest": "^4.1.6"
  },
  "overridesComment": "postcss: next@16.2.6 (latest) bundles postcss 8.4.31, flagged by GHSA-qx2v-qp2m-jg93 (XSS in the CSS stringifier — build-time only, not exploitable on our first-party CSS). Force the patched 8.5.x; remove once Next ships a fixed postcss.",
  "overrides": {
    "postcss": "^8.5.15"
  }
}
