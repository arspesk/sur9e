# sur9e — Environment Variables
# Copy this file to .env and fill in any values you need.
#
#   cp .env.example .env
#
# sur9e does NOT require API keys for the core flow:
#   - Claude Code handles its own authentication (run `claude login`).
#   - Playwright (PDF generation, liveness checks) needs no key.
#   - The batch scanner uses jobspy locally — no key needed.
#
# Everything below is OPTIONAL.

# ── Web server ─────────────────────────────────────────────────────────────
# Override the default localhost port (3000) when something else is bound.
# PORT=3000
